name               = "doh-fallback-worker"
main               = "worker.js"
compatibility_date = "2024-09-23"

# Local deployment template.
# Copy this file to `wrangler.toml` and replace the placeholder values
# with your own Cloudflare resource identifiers before deploying.

[[kv_namespaces]]
binding = "DOH_KV"
id      = "REPLACE_WITH_YOUR_KV_NAMESPACE_ID"

# Optional notes:
# - Keep `wrangler.toml` out of version control.
# - Use `npx wrangler deploy` for local deployment.
